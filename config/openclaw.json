{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": ["*"],
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "qwertz"
    }
  },
  "models": {
    "providers": {
      "lmstudio": {
        "baseUrl": "http://host.docker.internal:1234/v1",
        "apiKey": "lmstudio",
        "api": "openai-responses",  
        "models": [
          {
            "id": "qwen3.5-9b",
            "name": "Qwen 3 9B (Q4)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": { "primary": "lmstudio/qwen3.5-9b-q4_k_m" },
      "models": {
        "lmstudio/qwen3.5-9b-q4_k_m": { "alias": "Qwen 3 Local" }
      },
       "heartbeat": {
        "every": "5m"
      }
    }
  }
}
